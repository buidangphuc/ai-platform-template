ENVIRONMENT=dev
PROJECT_NAME="AI Solution Engineering Platform"
VERSION=0.1.0
DESCRIPTION="Reusable FastAPI foundation for AI solution engineering"
API_V1_PREFIX=/api/v1

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres # pragma: allowlist secret
POSTGRES_DB=ai_platform

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DATABASE=0
REDIS_TIMEOUT_SECONDS=5

API_KEY_PEPPER=change-me-local-dev-only # pragma: allowlist secret
API_KEY_BOOTSTRAP_TOKEN=change-me-local-bootstrap-token # pragma: allowlist secret
DEFAULT_RATE_LIMIT_PER_MINUTE=60

OTEL_EXPORTER_OTLP_ENDPOINT=
TRACE_CONTENT=redacted

CHAT_MODEL=
EMBEDDING_MODEL=
VECTOR_STORE=in_memory
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=.local/storage
JOB_BACKEND=in_process
OBSERVABILITY_BACKEND=debug
LLM_CACHE_BACKEND=noop
LLM_CACHE_ENABLED=false
AGENT_RUNTIME=simple
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

EXPERIMENT_TRACKER_BACKEND=local
LOCAL_EXPERIMENT_TRACKER_ROOT=research/experiments/local
MLFLOW_TRACKING_URI=file:./research/experiments/mlruns
MLFLOW_EXPERIMENT_NAME=ai-platform-template
