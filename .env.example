ENVIRONMENT=dev
PROJECT_NAME="AI Solution Engineering Platform"
VERSION=0.1.0
DESCRIPTION="Reusable FastAPI foundation for AI solution engineering"
API_V1_PREFIX=/api/v1

DATABASE_ENABLED=true
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres # pragma: allowlist secret
POSTGRES_DB=ai_platform
# Pool tuning. DB_POOL_SIZE = steady connections, DB_MAX_OVERFLOW = burst above pool.
# Recycle helps PgBouncer/closed-by-server idle timeouts.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DATABASE=0
REDIS_TIMEOUT_SECONDS=5

AUTH_BEARER_TOKEN=change-me-local-bearer-token # pragma: allowlist secret
AUTH_SUBJECT=local-user
AUTH_ROLES=admin
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REDIS_PREFIX=rate-limit
RATE_LIMIT_IP_ENABLED=true
RATE_LIMIT_IP_PER_MINUTE=600
RATE_LIMIT_PRINCIPAL_ENABLED=true
RATE_LIMIT_PRINCIPAL_PER_MINUTE=60
RATE_LIMIT_EXCLUDE_PATHS=/healthz,/readyz
IDEMPOTENCY_ENABLED=false
IDEMPOTENCY_BACKEND=postgres
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_IN_PROGRESS_TIMEOUT_SECONDS=60
IDEMPOTENCY_KEY_MAX_LENGTH=64
QUOTA_ENABLED=false
QUOTA_BACKEND=memory

LOG_LEVEL=INFO
LOG_JSON=false
LOG_ENQUEUE=false

# LangChain chat model target. Leave empty to use the local fake model.
# Examples: openai:gpt-4.1-mini, anthropic:claude-sonnet-4-5
CHAT_MODEL=
CHAT_FALLBACK_MODELS=
JUDGE_CHAT_MODEL=
RAG_ENABLED=false
RAG_BACKEND=memory
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_DEFAULT_TOP_K=5
RAG_EMBED_MODEL=
RAG_MOCK_EMBED_DIM=16
RAG_RETRIEVE_TIMEOUT_SECONDS=10

CACHE_ENABLED=false
CACHE_BACKEND=memory
CACHE_PREFIX=app
CACHE_DEFAULT_TTL_SECONDS=300

WEBHOOKS_ENABLED=false
WEBHOOK_SIGNING_SECRET=
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
WEBHOOK_TIMEOUT_SECONDS=10

OBJECTS_ENABLED=false
OBJECT_BACKEND=memory
OBJECT_PREFIX=app
OBJECT_S3_BUCKET=
OBJECT_S3_REGION=ap-southeast-1
OBJECT_S3_ENDPOINT_URL=

OUTBOX_ENABLED=false
OUTBOX_BACKEND=postgres

CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
TRUSTED_HOSTS=*
MAX_REQUEST_BODY_BYTES=10485760

SECURITY_HEADERS_ENABLED=false
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE_SECONDS=31536000

# GZip compression. Disable when reverse proxy (nginx/Cloudflare/ALB) already does gzip.
GZIP_ENABLED=false
GZIP_MIN_SIZE=1024
GZIP_COMPRESS_LEVEL=5

# Per-request timeout. Patterns in REQUEST_TIMEOUT_EXCLUDE_PATTERNS bypass it
# (e.g. SSE/streaming endpoints that intentionally hold the connection).
REQUEST_TIMEOUT_ENABLED=false
REQUEST_TIMEOUT_SECONDS=30
REQUEST_TIMEOUT_EXCLUDE_PATTERNS=/stream,/sse

# Track in-flight requests and wait up to GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS for
# them to finish on SIGTERM. Enable for k8s rolling deploys.
GRACEFUL_SHUTDOWN_ENABLED=false
GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS=30

# Async task infrastructure.
# QUEUE_BACKEND: memory (default) | redis | sqs | rabbitmq
# TASK_STORE_BACKEND: memory (default) | postgres | redis
QUEUE_ENABLED=true
QUEUE_BACKEND=memory
QUEUE_NAME=completions
SQS_QUEUE_URL=""
SQS_REGION=ap-southeast-1
SQS_ENDPOINT_URL=""
SQS_VISIBILITY_TIMEOUT_SECONDS=0
RABBITMQ_URL=""

TASKS_ENABLED=true
TASK_STORE_BACKEND=memory
TASK_REDIS_PREFIX=tasks
TASK_TTL_SECONDS=86400
TASKS_LEASE_SECONDS=300
TASKS_DISPATCH_BACKEND=queue

WORKER_MAX_CONCURRENT=10
WORKER_MAX_ATTEMPTS=3
WORKER_POLL_INTERVAL_SECONDS=0.5
WORKER_RECEIVE_BATCH_SIZE=10
WORKER_RECEIVE_WAIT_SECONDS=1.0

# OpenAPI docs. Set false in prod to hide /docs, /redoc, and /openapi.json.
DOCS_ENABLED=true

LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=lf_pk_local_ai_platform
LANGFUSE_SECRET_KEY=lf_sk_local_ai_platform # pragma: allowlist secret
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_PROMPT_CACHE_TTL_SECONDS=60
